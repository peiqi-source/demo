%% exp_measure.m 性能指标提升实验
clear;
clc;
close all;

%% setup paths
thisFile = mfilename("fullpath");
expDir = fileparts(thisFile);
rootDir = fileparts(expDir);
addpath(genpath(rootDir));

%% load data


%% set parameter
rng(1);
k = 5;
order = 3;
num_sampling = 3;
anchors = 10;
delta = 5;

multiple_anchors = [];
for t = 0:num_sampling
    multiple_anchors = [multiple_anchors, anchors*c+t*delta*c]
